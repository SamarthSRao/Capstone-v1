# HT-605 / HT-505 cloud env template for the NexusGear storefront.
# Copy values into .env.production before `npm run build` for AWS deploys.

VITE_API_URL=https://YOUR_API_ALB_OR_API_GATEWAY
VITE_SIMULATOR_URL=https://YOUR_SIMULATOR_OR_METRICS_PROXY
# simulator | cloud  — cloud mode polls VITE_CLOUD_METRICS_URL
VITE_TELEMETRY_MODE=cloud
VITE_CLOUD_METRICS_URL=https://YOUR_METRICS_PROXY/metrics
